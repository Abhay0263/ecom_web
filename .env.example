# PostgreSQL Database Settings
# Used by PostgreSQL container for configuration
POSTGRES_USER=ecom_user
POSTGRES_PASSWORD=ecom_secure_password
POSTGRES_DB=ecom_db

# Backend Service Settings
# Used by the backend Node.js container to connect to Postgres
DB_HOST=db
DB_PORT=5432
DB_USER=ecom_user
DB_PASSWORD=ecom_secure_password
DB_NAME=ecom_db
PORT=5000
